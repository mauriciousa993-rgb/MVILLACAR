# Backend environment variables
# Copy this file to backend/.env for local development.
# In Render, configure these values in the service Environment tab.

PORT=5000
NODE_ENV=development

# Required
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret

# Security
# Keep this in false in production. Enable only for initial bootstrap if needed.
ALLOW_SETUP_ADMIN=false
# Comma-separated frontend origins allowed by CORS.
# In production set your Vercel domain(s), for example:
# ALLOWED_ORIGINS=https://my-app.vercel.app,https://www.my-domain.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional local uploads directory
UPLOAD_DIR=./uploads

# Optional Cloudinary (recommended in Render to avoid ephemeral filesystem loss)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional OCR with OpenAI
# OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o-mini
# OPENAI_API_BASE_URL=https://api.openai.com/v1
